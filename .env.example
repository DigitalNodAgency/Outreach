# ── Google Sheets ──────────────────────────────────────────────────────────────
SPREADSHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Brevo SMTP ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_sender@yourdomain.com
SMTP_PASS=your_brevo_smtp_password
BREVO_API_KEY=your_brevo_api_key

# ── IMAP (reply logger — GitHub Actions secret) ────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_PASS=your_imap_app_password

# ── Notifications ──────────────────────────────────────────────────────────────
GMAIL_SENDER=your_notify_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
NOTIFY_EMAIL=where_summaries_go@gmail.com

# ── Lead Discovery & Enrichment ────────────────────────────────────────────────
PROSPEO_API_KEY=your_prospeo_api_key
APIFY_API_TOKEN=your_apify_api_token
SERPER_API_KEY=your_serper_api_key

# ── Outreach limits ────────────────────────────────────────────────────────────
DAILY_EMAIL_CAP=300
FOLLOWUP_DELAY_DAYS=4
MAX_FOLLOWUPS=3
SEND_DELAY_SECONDS=5
MAX_LEADS_PER_RUN=100

# ── ICP Config (fill after client onboarding) ──────────────────────────────────
ICP_PERSONA=[CLIENT_ICP_PERSONA]
ICP_COMPANY_SIZE=[CLIENT_COMPANY_SIZE]
ICP_INDUSTRIES=[CLIENT_INDUSTRIES]
ICP_REGIONS=[CLIENT_REGIONS]
ICP_DISQUALIFY=[CLIENT_DISQUALIFY_CONDITIONS]

# ── Landing page ───────────────────────────────────────────────────────────────
GAMMA_URL=https://your-landing-page-url.com

# ── Templates directory ────────────────────────────────────────────────────────
TEMPLATES_DIR=active/outreach/templates
